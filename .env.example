# Google OAuth Configuration (for Gmail integration)
# Get these from: https://console.cloud.google.com
# 1. Create project "Career CRM"
# 2. Enable "Gmail API" and "Google+ API"
# 3. Create OAuth 2.0 Web Application credentials
# 4. Add redirect URI: http://localhost:8080/auth/gmail/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Frontend URL (for OAuth callbacks)
FRONTEND_URL=http://localhost:8080

# Optional: Supabase Service Role Key (for deploying Edge Functions)
# Only needed if using Supabase CLI
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Supabase Anon Key (used in Edge Functions)
# SUPABASE_ANON_KEY=your-anon-key
