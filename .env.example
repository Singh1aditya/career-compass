# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>
VITE_SUPABASE_PROJECT_ID=<your-project-id>
SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>
SUPABASE_URL=https://<your-project-id>.supabase.co

# Google OAuth Configuration (for Gmail integration)
# Get these from: https://console.cloud.google.com
# 1. Create project, enable Gmail API + Google Calendar API
# 2. APIs & Services → Credentials → Create OAuth 2.0 Web Application client
# 3. Add authorized redirect URI: http://localhost:8080/auth/gmail/callback
# 4. Client secret goes into Supabase Edge Function secrets (not here)
VITE_GOOGLE_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com

# Frontend URL (for OAuth callbacks)
FRONTEND_URL=http://localhost:8080

# Supabase Edge Function secrets (set via Supabase Dashboard or CLI — never commit these)
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# GOOGLE_CLIENT_SECRET=<your-google-client-secret>
# ANTHROPIC_API_KEY=<your-anthropic-api-key>
